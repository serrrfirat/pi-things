{
  "packages": [
    "npm:pi-ask-user",
    {
      "source": "npm:oh-pi",
      "extensions": [
        "-pi-package/extensions/bg-process.ts"
      ]
    },
    "npm:pi-subagents",
    "npm:pi-markdown-preview",
    "npm:@juanibiapina/pi-extension-settings",
    "npm:@guwidoe/pi-prompt-suggester",
    "npm:pi-extmgr",
    "npm:pi-librarian",
    "npm:pi-web-access",
    "npm:pi-interview",
    {
      "source": "git:https://github.com/hasit/pi-community-themes",
      "themes": [
        "themes/*.json",
        "!themes/catppuccin-mocha.json",
        "!themes/nord.json"
      ]
    },
    "npm:taskplane",
    "npm:pi-mcp-adapter",
    "npm:@plannotator/pi-extension",
    "npm:pi-btw",
    "npm:pi-sync-config",
    "npm:pi-ssh",
    "git:https://github.com/fluxgear/pi-thinking-steps@v0.9.6",
    "npm:@ff-labs/pi-fff",
    "npm:pi-memory-md",
    "git:github.com/badlogic/pi-diff-review@1584211692c49780ecd0f490a82762b0823fd475",
    "npm:@devkade/pi-plan",
    "npm:pi-simplify",
    "npm:pi-add-dir",
    "npm:@juanibiapina/pi-powerbar",
    "npm:@tmustier/pi-usage-extension"
  ],
  "defaultProvider": "openai-codex",
  "defaultModel": "gpt-5.4",
  "defaultThinkingLevel": "medium",
  "theme": "dark",
  "quietStartup": false,
  "transport": "auto",
  "hideThinkingBlock": true,
  "subagents": {
    "agentOverrides": {
      "context-builder": {
        "model": ""
      },
      "planner": {
        "model": ""
      },
      "researcher": {
        "model": ""
      },
      "reviewer": {
        "model": ""
      },
      "scout": {
        "model": ""
      },
      "worker": {
        "model": ""
      }
    }
  }
}
